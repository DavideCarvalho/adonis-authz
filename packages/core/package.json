{
  "name": "@adonis-agora/authz",
  "version": "0.7.0",
  "description": "Bouncer-integrated, DB-backed RBAC for AdonisJS — roles, permissions, wildcard matching and multi-tenancy on top of @adonisjs/bouncer, with pluggable stores (Lucid / in-memory). Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-authz.git",
    "directory": "packages/core"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./authz_provider": {
      "types": "./dist/providers/authz_provider.d.ts",
      "import": "./dist/providers/authz_provider.js",
      "default": "./dist/providers/authz_provider.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "import": "./dist/configure.js",
      "default": "./dist/configure.js"
    },
    "./commands": {
      "types": "./dist/commands/main.d.ts",
      "import": "./dist/commands/main.js",
      "default": "./dist/commands/main.js"
    },
    "./mixins": {
      "types": "./dist/src/mixins.d.ts",
      "import": "./dist/src/mixins.js",
      "default": "./dist/src/mixins.js"
    },
    "./middleware": {
      "types": "./dist/src/middleware.d.ts",
      "import": "./dist/src/middleware.js",
      "default": "./dist/src/middleware.js"
    },
    "./provisioning": {
      "types": "./dist/src/provisioning.d.ts",
      "import": "./dist/src/provisioning.js",
      "default": "./dist/src/provisioning.js"
    },
    "./scope": {
      "types": "./dist/src/scope_kit.d.ts",
      "import": "./dist/src/scope_kit.js",
      "default": "./dist/src/scope_kit.js"
    },
    "./http": {
      "types": "./dist/src/http.d.ts",
      "import": "./dist/src/http.js",
      "default": "./dist/src/http.js"
    },
    "./testing": {
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js",
      "default": "./dist/src/testing.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy:stubs",
    "copy:stubs": "mkdir -p dist/stubs/config dist/stubs/abilities dist/stubs/database/migrations && cp stubs/config/authz.stub dist/stubs/config/authz.stub && cp stubs/abilities/authz.stub dist/stubs/abilities/authz.stub && cp -r stubs/database/migrations/. dist/stubs/database/migrations/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@adonis-agora/diagnostics": "^0.1.0",
    "@adonisjs/bouncer": "^4.0.0",
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/lucid": "^22.4.0"
  },
  "peerDependenciesMeta": {
    "@adonis-agora/diagnostics": {
      "optional": true
    },
    "@adonisjs/bouncer": {
      "optional": true
    },
    "@adonisjs/lucid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/bouncer": "^4.0.0",
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/lucid": "^22.4.0",
    "@types/node": "^20.0.0",
    "@vinejs/vine": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "luxon": "^3.4.0",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.4.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "bouncer",
    "authorization",
    "authz",
    "rbac",
    "roles",
    "permissions",
    "acl",
    "multi-tenancy",
    "lucid",
    "agora"
  ]
}
